# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
*.log

# next.js
/.next/
/out/
next-env.d.ts

# production
/build
/dist

# misc
.DS_Store
*.pem
.idea
.vscode

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files — NEVER commit real secrets
.env
.env*.local
.env.local
.env.development
.env.development.local
.env.production
.env.production.local
.env.test
.env.test.local
.env.staging
# Keep only example/template files
!.env.example
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo

# turbo
.turbo

# playwright
/test-results/
/playwright-report/
/playwright/.cache/

# Tokens & credentials
token.txt
*.key

# Large test/error output
eslint_out.json
test_output.txt
next-env.d.ts
